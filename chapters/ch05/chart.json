{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Healthcare Financing Mix, 2022",
    "subtitle": "Each square = 1% of total health spending. Sources: World Bank (OOP) + DOSM MNHA (public/private split).",
    "font": "Open Sans",
    "fontSize": 19,
    "fontWeight": "bold",
    "color": "#003580",
    "subtitleFont": "Open Sans",
    "subtitleFontSize": 14,
    "subtitleColor": "#666666",
    "subtitlePadding": 6,
    "anchor": "start"
  },
  "data": {
    "url": "data.json"
  },
  "mark": {
    "type": "rect",
    "stroke": "white",
    "strokeWidth": 2,
    "cornerRadius": 2
  },
  "encoding": {
    "x": {
      "field": "col",
      "type": "ordinal",
      "axis": null
    },
    "y": {
      "field": "row",
      "type": "ordinal",
      "scale": {
        "reverse": true
      },
      "axis": null
    },
    "color": {
      "field": "category",
      "type": "nominal",
      "sort": [
        "Government",
        "Private Insurance",
        "Out-of-Pocket"
      ],
      "scale": {
        "domain": [
          "Government",
          "Private Insurance",
          "Out-of-Pocket"
        ],
        "range": [
          "#003580",
          "#F4C300",
          "#C8102E"
        ]
      },
      "legend": {
        "title": null,
        "labelFont": "Open Sans",
        "labelFontSize": 11,
        "symbolSize": 120,
        "orient": "bottom",
        "direction": "horizontal"
      }
    },
    "tooltip": [
      {
        "field": "category",
        "title": "Source"
      },
      {
        "field": "pct",
        "title": "Share of total health spend (%)",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "background": "#F5F5F0"
  }
}