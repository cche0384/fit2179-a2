{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Healthcare Access Index by State, 2022–2023",
    "subtitle": "Most states fall below the national average for doctor density (~23.4/10k). Outlier: Putrajaya (172/10k) excluded for scale.",
    "font": "Open Sans",
    "fontSize": 19,
    "fontWeight": "bold",
    "color": "#003580",
    "subtitleFont": "Open Sans",
    "subtitleFontSize": 14,
    "subtitleColor": "#666666",
    "subtitlePadding": 6,
    "anchor": "start"
  },
  "width": 500,
  "height": 350,
  "data": {
    "url": "data.json"
  },
  "transform": [
    {
      "filter": "datum.state != 'W.P. Putrajaya'"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#d62728",
        "strokeDash": [
          4,
          4
        ],
        "size": 1.5
      },
      "encoding": {
        "x": {
          "datum": 23.4
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#666",
        "strokeDash": [
          2,
          2
        ],
        "size": 1
      },
      "encoding": {
        "y": {
          "datum": 8.1
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 5,
        "dy": -5,
        "fontSize": 9,
        "font": "Open Sans",
        "color": "#d62728",
        "text": "Natl Doctor Avg (23.4)"
      },
      "encoding": {
        "x": {
          "datum": 23.4
        },
        "y": {
          "datum": 11
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "bottom",
        "dx": -5,
        "dy": -2,
        "fontSize": 9,
        "font": "Open Sans",
        "color": "#666",
        "text": "Avg Mortality (8.1)"
      },
      "encoding": {
        "x": {
          "datum": 38
        },
        "y": {
          "datum": 8.1
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "stroke": "#333",
        "strokeWidth": 0.5,
        "opacity": 0.8
      },
      "encoding": {
        "x": {
          "field": "doctors_per_10k",
          "type": "quantitative",
          "title": "Doctors per 10,000 People",
          "scale": {
            "domain": [
              10,
              38
            ],
            "zero": false,
            "nice": false
          }
        },
        "y": {
          "field": "imr_2023",
          "type": "quantitative",
          "title": "Infant Mortality Rate (per 1,000 live births)",
          "scale": {
            "domain": [
              6,
              11
            ],
            "zero": false,
            "nice": false
          }
        },
        "size": {
          "field": "population",
          "type": "quantitative",
          "scale": {
            "range": [
              50,
              2000
            ]
          },
          "legend": null
        },
        "color": {
          "field": "tier",
          "type": "nominal",
          "sort": [
            "Critical",
            "Under-resourced",
            "Adequate",
            "Well-served"
          ],
          "scale": {
            "domain": [
              "Critical",
              "Under-resourced",
              "Adequate",
              "Well-served"
            ],
            "range": [
              "#C8102E",
              "#E8786A",
              "#7CA0D8",
              "#003580"
            ]
          },
          "legend": {
            "title": "Access Tier",
            "orient": "top-right"
          }
        },
        "tooltip": [
          {
            "field": "state",
            "title": "State"
          },
          {
            "field": "region",
            "title": "Region"
          },
          {
            "field": "doctors_per_10k",
            "title": "Doctors/10k",
            "format": ".1f"
          },
          {
            "field": "imr_2023",
            "title": "IMR 2023",
            "format": ".1f"
          },
          {
            "field": "population",
            "title": "Population",
            "format": ","
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.state != 'Terengganu' && datum.state != 'Pahang' && datum.state != 'Selangor'"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 9,
        "font": "Open Sans",
        "fontStyle": "italic"
      },
      "encoding": {
        "x": {
          "field": "doctors_per_10k",
          "type": "quantitative"
        },
        "y": {
          "field": "imr_2023",
          "type": "quantitative"
        },
        "text": {
          "field": "state"
        },
        "align": {
          "condition": [
            {
              "test": "datum.state == 'W.P. Labuan'",
              "value": "right"
            }
          ],
          "value": "center"
        },
        "dx": {
          "condition": [
            {
              "test": "datum.state == 'W.P. Labuan'",
              "value": 10
            }
          ],
          "value": 0
        },
        "dy": {
          "condition": [
            {
              "test": "datum.state == 'Perak'",
              "value": -12
            },
            {
              "test": "datum.state == 'Kedah' || datum.state == 'Johor' || datum.state == 'Sarawak' || datum.state == 'Melaka'",
              "value": 15
            }
          ],
          "value": 10
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.state == 'Terengganu'"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 9,
        "font": "Open Sans",
        "fontStyle": "italic",
        "align": "right",
        "dx": -8,
        "dy": -5
      },
      "encoding": {
        "x": {
          "field": "doctors_per_10k",
          "type": "quantitative"
        },
        "y": {
          "field": "imr_2023",
          "type": "quantitative"
        },
        "text": {
          "field": "state"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.state == 'Pahang'"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 9,
        "font": "Open Sans",
        "fontStyle": "italic",
        "align": "left",
        "dx": 8,
        "dy": 5
      },
      "encoding": {
        "x": {
          "field": "doctors_per_10k",
          "type": "quantitative"
        },
        "y": {
          "field": "imr_2023",
          "type": "quantitative"
        },
        "text": {
          "field": "state"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.state == 'Selangor'"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 9,
        "font": "Open Sans",
        "fontStyle": "italic",
        "align": "center",
        "dx": 0,
        "dy": -18
      },
      "encoding": {
        "x": {
          "field": "doctors_per_10k",
          "type": "quantitative"
        },
        "y": {
          "field": "imr_2023",
          "type": "quantitative"
        },
        "text": {
          "field": "state"
        }
      }
    }
  ],
  "config": {
    "background": "#F5F5F0",
    "axis": {
      "labelFont": "Open Sans",
      "titleFont": "Open Sans",
      "grid": true,
      "gridColor": "#e0e0e0"
    },
    "legend": {
      "labelFont": "Open Sans",
      "titleFont": "Open Sans"
    }
  }
}