{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Health Spending vs. Mortality — Who Gets the Grease?",
    "subtitle": "Total health expenditure per capita (public + private)  ·  MNHA 2022, MOH Malaysia  ·  OpenDOSM Vital Statistics 2022",
    "font": "Poppins",
    "fontSize": 15,
    "fontWeight": "bold",
    "color": "#003580",
    "subtitleFont": "Poppins",
    "subtitleFontSize": 10,
    "subtitleColor": "#666666",
    "subtitlePadding": 6
  },
  "data": {"url": "data.json"},
  "transform": [
    {
      "calculate": "datum.state == 'W.P. Kuala Lumpur' ? 'W.P. KL' : datum.state == 'Negeri Sembilan' ? 'N. Sembilan' : datum.state",
      "as": "state_label"
    },
    {
      "calculate": "datum.alignment == 'under-resourced' ? 'Under-resourced' : datum.alignment == 'spending-not-helping' ? 'Spending not helping' : datum.alignment == 'efficient' ? 'Efficient' : 'Outlier (private-driven)'",
      "as": "status"
    }
  ],
  "layer": [
    {
      "mark": {"type": "rule", "strokeDash": [5, 3], "color": "#CCCCCC", "strokeWidth": 1},
      "encoding": {"y": {"datum": 6.4, "type": "quantitative"}}
    },
    {
      "mark": {"type": "rule", "strokeDash": [5, 3], "color": "#CCCCCC", "strokeWidth": 1},
      "encoding": {"x": {"datum": 2023, "type": "quantitative"}}
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 7.5, "fontStyle": "italic", "color": "#AAAAAA",
        "align": "left", "dy": -5
      },
      "encoding": {
        "x": {"datum": 1200, "type": "quantitative"},
        "y": {"datum": 6.4, "type": "quantitative"},
        "text": {"value": "avg death rate"}
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 7.5, "fontStyle": "italic", "color": "#AAAAAA",
        "align": "left", "baseline": "top", "dx": 4, "dy": 3
      },
      "encoding": {
        "x": {"datum": 2023, "type": "quantitative"},
        "y": {"datum": 10.3, "type": "quantitative"},
        "text": {"value": "avg spending"}
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "opacity": 0.85,
        "stroke": "#ffffff",
        "strokeWidth": 0.8
      },
      "encoding": {
        "x": {
          "field": "spending_per_capita",
          "type": "quantitative",
          "scale": {"type": "log", "base": 10, "domain": [1100, 8500]},
          "axis": {
            "title": "Health Expenditure per Capita, RM (log scale)  —  2022",
            "format": ",.0f",
            "values": [1500, 2000, 2500, 3000, 5000, 7000],
            "titleFont": "Poppins",
            "titleFontSize": 11,
            "labelFont": "Poppins",
            "grid": false
          }
        },
        "y": {
          "field": "mortality_rate",
          "type": "quantitative",
          "scale": {"domain": [1.5, 11]},
          "axis": {
            "title": "Crude Death Rate (per 1,000 population)",
            "titleFont": "Poppins",
            "titleFontSize": 11,
            "labelFont": "Poppins",
            "grid": false
          }
        },
        "size": {
          "field": "population",
          "type": "quantitative",
          "scale": {"range": [80, 2400]},
          "legend": null
        },
        "color": {
          "field": "status",
          "type": "nominal",
          "scale": {
            "domain": ["Under-resourced", "Spending not helping", "Efficient", "Outlier (private-driven)"],
            "range": ["#C8102E", "#E08800", "#2a9d4e", "#AAAAAA"]
          },
          "legend": {
            "title": null,
            "orient": "bottom-right",
            "labelFont": "Poppins",
            "labelFontSize": 9.5,
            "symbolSize": 90,
            "symbolStrokeWidth": 0
          }
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "spending_per_capita", "title": "Spending / capita (RM)", "format": ",.0f"},
          {"field": "mortality_rate", "title": "Death rate (per 1,000)", "format": ".1f"},
          {"field": "spending_deviation", "title": "vs. national avg spending (%)", "format": "+.0f"},
          {"field": "population", "title": "Population", "format": ",.0f"},
          {"field": "status", "title": "Classification"},
          {"field": "data_note", "title": "Data note"}
        ]
      }
    },
    {
      "mark": {"type": "text", "dy": -12, "fontSize": 8, "font": "Poppins"},
      "encoding": {
        "x": {"field": "spending_per_capita", "type": "quantitative"},
        "y": {"field": "mortality_rate", "type": "quantitative"},
        "text": {"field": "state_label"},
        "color": {
          "field": "status",
          "type": "nominal",
          "scale": {
            "domain": ["Under-resourced", "Spending not helping", "Efficient", "Outlier (private-driven)"],
            "range": ["#C8102E", "#E08800", "#2a9d4e", "#888888"]
          }
        }
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "background": "#F5F5F0"
  }
}
