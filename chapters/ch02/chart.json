{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 560,
  "height": 320,
  "title": {
    "text": "Total Doctors by State, 2022",
    "subtitle": "Circle area ∝ total registered doctors. National avg = 17.8 doctors per 10,000 pop. Excl. W.P. Putrajaya (outlier 172/10k).",
    "font": "Open Sans",
    "fontSize": 19,
    "fontWeight": "bold",
    "color": "#003580",
    "subtitleFont": "Open Sans",
    "subtitleFontSize": 14,
    "subtitleColor": "#666666",
    "anchor": "start",
    "subtitlePadding": 6
  },
  "projection": {
    "type": "mercator"
  },
  "data": {
    "url": "../ch01/malaysia-states-compact.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "transform": [
    {
      "lookup": "properties.NAME_1",
      "from": {
        "data": {
          "url": "data.json"
        },
        "key": "gadm_name",
        "fields": [
          "state",
          "doctors",
          "doctors_per_10k",
          "population",
          "above_avg",
          "tier",
          "lon",
          "lat"
        ]
      }
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "geoshape",
        "fill": "#C4D4E4",
        "stroke": "#7A92A8",
        "strokeWidth": 1.2
      }
    },
    {
      "transform": [
        {
          "filter": "datum.state !== 'W.P. Putrajaya' && datum.doctors != null"
        }
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.72,
        "strokeWidth": 1.5
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "size": {
          "field": "doctors",
          "type": "quantitative",
          "scale": {
            "type": "sqrt",
            "range": [
              10,
              800
            ]
          },
          "legend": {
            "title": "Total doctors",
            "values": [
              500,
              2000,
              10000
            ],
            "symbolType": "circle",
            "orient": "top-left",
            "direction": "horizontal",
            "titleOrient": "left",
            "titleFont": "Open Sans",
            "labelFont": "Open Sans",
            "titleFontSize": 9,
            "labelFontSize": 8,
            "rowPadding": 0,
            "columnPadding": 6,
            "symbolOpacity": 0.7,
            "padding": 5,
            "offset": 8
          }
        },
        "color": {
          "field": "tier",
          "type": "nominal",
          "scale": {
            "domain": [
              "Above national avg",
              "Below national avg"
            ],
            "range": [
              "#003580",
              "#C8102E"
            ]
          },
          "legend": {
            "title": "Doctors per 10,000 pop.",
            "titleFont": "Open Sans",
            "titleFontSize": 9,
            "labelFont": "Open Sans",
            "labelFontSize": 9,
            "orient": "bottom-left",
            "direction": "vertical",
            "symbolType": "circle",
            "symbolOpacity": 0.75,
            "symbolSize": 80,
            "padding": 20
          }
        },
        "stroke": {
          "field": "tier",
          "type": "nominal",
          "scale": {
            "domain": [
              "Above national avg",
              "Below national avg"
            ],
            "range": [
              "#001f5c",
              "#8B0000"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "state",
            "title": "State"
          },
          {
            "field": "doctors",
            "title": "Total doctors",
            "format": ","
          },
          {
            "field": "doctors_per_10k",
            "title": "Doctors per 10,000",
            "format": ".1f"
          },
          {
            "field": "population",
            "title": "Population (2022)",
            "format": ","
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": "#F5F5F0"
  }
}