{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 380,
  "height": 380,
  "title": {
    "text": "Causes of Death in Malaysia, 2019",
    "subtitle": "Tile area = share of all deaths. World Bank broad categories · WHO GHE 2019 subcategory breakdown.",
    "font": "Open Sans",
    "fontSize": 19,
    "fontWeight": "bold",
    "color": "#003580",
    "subtitleFont": "Open Sans",
    "subtitleFontSize": 14,
    "subtitleColor": "#666666",
    "subtitlePadding": 6,
    "anchor": "start"
  },
  "data": {
    "url": "data.json"
  },
  "layer": [
    {
      "mark": {
        "type": "rect",
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "x0",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": null
        },
        "x2": {
          "field": "x1",
          "type": "quantitative"
        },
        "y": {
          "field": "y0",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "axis": null
        },
        "y2": {
          "field": "y1",
          "type": "quantitative"
        },
        "color": {
          "field": "subcategory",
          "type": "nominal",
          "scale": {
            "domain": [
              "Cardiovascular",
              "Cancers",
              "Diabetes",
              "Chronic Resp.",
              "Other NCDs",
              "Lower Resp. Infections",
              "Tuberculosis",
              "Septicaemia",
              "Other Infections",
              "Road Traffic",
              "Falls",
              "Self-harm",
              "Other External"
            ],
            "range": [
              "#003580",
              "#1a4e93",
              "#3367a6",
              "#4d80b9",
              "#6699cc",
              "#C8102E",
              "#d84060",
              "#e87090",
              "#f5a0b4",
              "#e6a800",
              "#f0c030",
              "#f5d878",
              "#f9e8b0"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "category",
            "title": "Cause group"
          },
          {
            "field": "subcategory",
            "title": "Disease"
          },
          {
            "field": "pct",
            "title": "% of all deaths",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "font": "Open Sans",
        "fontSize": 9,
        "fontWeight": "bold",
        "align": "center",
        "baseline": "middle",
        "color": "#ffffff",
        "clip": true
      },
      "encoding": {
        "x": {
          "field": "cx",
          "type": "quantitative",
          "axis": null
        },
        "y": {
          "field": "cy",
          "type": "quantitative",
          "axis": null
        },
        "text": {
          "field": "subcategory",
          "type": "nominal"
        },
        "color": {
          "condition": [
            {
              "test": "datum.category == 'External'",
              "value": "#333333"
            }
          ],
          "value": "#ffffff"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "font": "Open Sans",
        "fontSize": 8,
        "fontStyle": "italic",
        "align": "center",
        "baseline": "middle",
        "clip": true,
        "dy": 12
      },
      "encoding": {
        "x": {
          "field": "cx",
          "type": "quantitative",
          "axis": null
        },
        "y": {
          "field": "cy",
          "type": "quantitative",
          "axis": null
        },
        "text": {
          "field": "pct",
          "type": "quantitative",
          "format": ".1f"
        },
        "color": {
          "condition": [
            {
              "test": "datum.category == 'External'",
              "value": "#555555"
            }
          ],
          "value": "#e0e8f0"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": "#F5F5F0",
    "axisX": { "disable": true },
    "axisY": { "disable": true }
  }
}