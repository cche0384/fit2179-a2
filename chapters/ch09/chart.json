{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Child Death Rates by State, 2000 vs 2023",
    "subtitle": "○ = 2000 rate  ● = 2023 rate. Blue = Improved  Red = Worsened. ⚠ Sabah 2000 value underreported (dashed).",
    "font": "Open Sans",
    "fontSize": 19,
    "fontWeight": "bold",
    "color": "#003580",
    "subtitleFont": "Open Sans",
    "subtitleFontSize": 14,
    "subtitleColor": "#666666",
    "subtitlePadding": 6,
    "anchor": "start"
  },
  "width": 480,
  "height": 340,
  "data": {
    "url": "data.json"
  },
  "layer": [
    {
      "transform": [
        {
          "filter": "datum.tier != 'national'"
        }
      ],
      "mark": {
        "type": "rule",
        "strokeWidth": 2.5
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {
            "field": "imr_2023",
            "order": "descending"
          },
          "axis": {
            "title": null,
            "labelFont": "Open Sans",
            "labelFontSize": 10,
            "labelColor": "#333333"
          }
        },
        "x": {
          "field": "imr_2000",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              16
            ]
          },
          "axis": {
            "title": "Deaths per 1,000 live births",
            "titleFont": "Open Sans",
            "titleFontSize": 10,
            "labelFont": "Open Sans",
            "labelFontSize": 9,
            "grid": true,
            "gridColor": "#e8e8e8"
          }
        },
        "x2": {
          "field": "imr_2023"
        },
        "color": {
          "condition": [
            {
              "test": "datum.improvement > 0",
              "value": "#003580"
            },
            {
              "test": "datum.improvement < 0",
              "value": "#C8102E"
            }
          ],
          "value": "#666666"
        },
        "strokeDash": {
          "condition": {
            "test": "datum.note == 'underreported'",
            "value": [
              5,
              3
            ]
          },
          "value": [
            1,
            0
          ]
        },
        "opacity": {
          "condition": {
            "test": "datum.note == 'underreported'",
            "value": 0.55
          },
          "value": 1.0
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.tier != 'national'"
        }
      ],
      "mark": {
        "type": "point",
        "filled": false,
        "size": 55,
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {
            "field": "imr_2023",
            "order": "descending"
          }
        },
        "x": {
          "field": "imr_2000",
          "type": "quantitative"
        },
        "color": {
          "condition": [
            {
              "test": "datum.improvement > 0",
              "value": "#003580"
            },
            {
              "test": "datum.improvement < 0",
              "value": "#C8102E"
            }
          ],
          "value": "#666666"
        },
        "tooltip": [
          {
            "field": "state",
            "title": "State"
          },
          {
            "field": "imr_2000",
            "title": "2000 (per 1,000)",
            "format": ".1f"
          },
          {
            "field": "imr_2023",
            "title": "2023 (per 1,000)",
            "format": ".1f"
          },
          {
            "field": "improvement",
            "title": "Change (+ = improved)",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.tier != 'national'"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 55
      },
      "encoding": {
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {
            "field": "imr_2023",
            "order": "descending"
          }
        },
        "x": {
          "field": "imr_2023",
          "type": "quantitative"
        },
        "color": {
          "condition": [
            {
              "test": "datum.improvement > 0",
              "value": "#003580"
            },
            {
              "test": "datum.improvement < 0",
              "value": "#C8102E"
            }
          ],
          "value": "#666666"
        },
        "tooltip": [
          {
            "field": "state",
            "title": "State"
          },
          {
            "field": "imr_2000",
            "title": "2000 (per 1,000)",
            "format": ".1f"
          },
          {
            "field": "imr_2023",
            "title": "2023 (per 1,000)",
            "format": ".1f"
          },
          {
            "field": "improvement",
            "title": "Change (+ = improved)",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.tier == 'national'"
        }
      ],
      "mark": {
        "type": "rule",
        "color": "#F4C300",
        "strokeWidth": 2,
        "strokeDash": [
          5,
          3
        ],
        "opacity": 1.0
      },
      "encoding": {
        "x": {
          "field": "imr_2023",
          "type": "quantitative"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.tier == 'national'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "bottom",
        "dy": -5,
        "fontSize": 10,
        "font": "Open Sans",
        "color": "#F4C300",
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "imr_2023",
          "type": "quantitative"
        },
        "y": {
          "value": 0
        },
        "text": {
          "value": "National Avg (2023)"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": "#F5F5F0",
    "padding": {
      "top": 30
    }
  }
}