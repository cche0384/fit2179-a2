{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Early Childhood Death Rate by State, 2000–2023",
    "subtitle": "Deaths per 1,000 live births. Darker = higher rate. Sorted by 2023 rate (worst top). Source: DOSM. Sabah 2000–2013: underreported prior to registry reform.",
    "font": "Open Sans",
    "fontSize": 19,
    "fontWeight": "bold",
    "color": "#003580",
    "subtitleFont": "Open Sans",
    "subtitleFontSize": 14,
    "subtitleColor": "#666666",
    "subtitlePadding": 6,
    "anchor": "start"
  },
  "data": {
    "url": "data.json"
  },
  "mark": {
    "type": "rect",
    "stroke": "#ffffff",
    "strokeWidth": 0.6
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "axis": {
        "title": null,
        "labelFont": "Open Sans",
        "labelFontSize": 10,
        "labelAngle": -45,
        "values": [
          2000,
          2005,
          2010,
          2015,
          2020,
          2023
        ]
      }
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": {
        "field": "state_order",
        "order": "ascending"
      },
      "axis": {
        "title": null,
        "labelFont": "Open Sans",
        "labelFontSize": 11
      }
    },
    "color": {
      "field": "imr",
      "type": "quantitative",
      "scale": {
        "scheme": "reds",
        "domain": [
          4,
          14
        ]
      },
      "legend": {
        "title": "Deaths per 1,000 live births",
        "titleFont": "Open Sans",
        "labelFont": "Open Sans",
        "titleFontSize": 10,
        "labelFontSize": 9,
        "direction": "horizontal",
        "orient": "bottom",
        "gradientLength": 200
      }
    },
    "tooltip": [
      {
        "field": "state",
        "title": "State"
      },
      {
        "field": "year",
        "title": "Year"
      },
      {
        "field": "imr",
        "title": "Death rate (per 1,000)",
        "format": ".1f"
      },
      {
        "field": "imr_change_pct",
        "title": "Change since 2000 (%)",
        "format": "+.1f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "background": "#F5F5F0",
    "axis": {
      "grid": false
    }
  }
}