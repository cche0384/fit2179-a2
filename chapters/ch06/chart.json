{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Child Stunting Rates by Region",
    "subtitle": "☹️ = stunted (chronic malnutrition). Malaysia & ASEAN: World Bank 2022. Sabah & Selangor: NHMS 2019.",
    "font": "Open Sans",
    "fontSize": 19,
    "fontWeight": "bold",
    "color": "#003580",
    "subtitleFont": "Open Sans",
    "subtitleFontSize": 14,
    "subtitleColor": "#666666",
    "subtitlePadding": 6,
    "anchor": "start"
  },
  "data": {
    "url": "data.json"
  },
  "height": {
    "step": 48
  },
  "layer": [
    {
      "mark": {
        "type": "text",
        "fontSize": 34,
        "font": "Open Sans",
        "baseline": "middle"
      },
      "encoding": {
        "x": {
          "field": "icon_index",
          "type": "ordinal",
          "axis": {
            "title": null,
            "labels": false,
            "ticks": false,
            "domainWidth": 0
          }
        },
        "y": {
          "field": "group",
          "type": "nominal",
          "sort": {
            "field": "order",
            "order": "ascending"
          },
          "axis": {
            "title": null,
            "labelFont": "Open Sans",
            "labelFontSize": 13,
            "labelFontWeight": "bold",
            "labelColor": "#003580"
          }
        },
        "color": {
          "condition": {
            "test": "datum.stunted",
            "value": "#C8102E"
          },
          "value": "#D0D8E8"
        },
        "text": {
          "condition": {
            "test": "datum.stunted",
            "value": "☹️"
          },
          "value": "●"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.icon_index == 9"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 12,
        "font": "Open Sans",
        "fontWeight": "bold",
        "align": "left",
        "dx": 28,
        "baseline": "middle"
      },
      "encoding": {
        "x": {
          "field": "icon_index",
          "type": "ordinal"
        },
        "y": {
          "field": "group",
          "type": "nominal",
          "sort": {
            "field": "order",
            "order": "ascending"
          }
        },
        "text": {
          "field": "rate",
          "format": ".1f",
          "formatType": "number"
        },
        "color": {
          "condition": {
            "test": "datum.group == 'Sabah'",
            "value": "#C8102E"
          },
          "value": "#555555"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.icon_index == 9"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 10,
        "font": "Open Sans",
        "align": "left",
        "dx": 55,
        "baseline": "middle",
        "color": "#888888"
      },
      "encoding": {
        "x": {
          "field": "icon_index",
          "type": "ordinal"
        },
        "y": {
          "field": "group",
          "type": "nominal",
          "sort": {
            "field": "order",
            "order": "ascending"
          }
        },
        "text": {
          "value": "%"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": "#F5F5F0",
    "axis": {
      "grid": false
    }
  }
}